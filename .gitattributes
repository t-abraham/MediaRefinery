# Default: let git decide line endings, normalize to LF in the repo.
* text=auto eol=lf

# Frontend toolchain expects LF; explicit for the noisy categories.
*.ts        text eol=lf
*.tsx       text eol=lf
*.js        text eol=lf
*.cjs       text eol=lf
*.mjs       text eol=lf
*.json      text eol=lf
*.html      text eol=lf
*.css       text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf

# Python
*.py        text eol=lf
*.toml      text eol=lf
*.cfg       text eol=lf

# Shell + Windows scripts: keep native to each.
*.sh        text eol=lf
*.bat       text eol=crlf
*.ps1       text eol=crlf

# Binaries
*.png       binary
*.jpg       binary
*.jpeg      binary
*.gif       binary
*.ico       binary
*.onnx      binary
*.gguf      binary
