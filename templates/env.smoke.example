# Placeholder-only live Immich smoke environment.
# Copy to .env.smoke at the repository root and replace values locally.
# .env.smoke is ignored by Git; never commit real values.
# Never paste these values into chat, issues, or PRs.

# v1 smoke vars (existing)
IMMICH_API_KEY=REPLACE_WITH_SHORT_LIVED_SMOKE_API_KEY
MEDIAREFINERY_CONFIG=tmp/immich-smoke.config.yml

# v2 Phase A discovery vars (additional)
# Used only for live verification of the Immich endpoints v2 depends on
# (proxy login, /users/me, Locked Folder visibility/PIN). Discovery
# scripts read these locally and never echo or commit them.
IMMICH_URL=https://REPLACE_WITH_DISPOSABLE_IMMICH_HOST
IMMICH_TEST_USER_EMAIL=REPLACE_WITH_DISPOSABLE_USER_EMAIL
IMMICH_TEST_USER_PASSWORD=REPLACE_WITH_DISPOSABLE_USER_PASSWORD
# Optional: a Locked Folder PIN already set on the test user so the PIN-set
# endpoint can be skipped during discovery. Leave blank to test PIN-set too.
IMMICH_TEST_USER_LOCKED_PIN=
